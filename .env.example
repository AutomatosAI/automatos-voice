# Voice Service Configuration
ENVIRONMENT=development
LOG_LEVEL=info

# STT (Speech-to-Text)
WHISPER_MODEL=Systran/faster-whisper-large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# TTS (Text-to-Speech)
TTS_DEFAULT_MODEL=kokoro
TTS_DEFAULT_VOICE=af_heart

# Service
HOST=0.0.0.0
PORT=8300

# Monitoring (PRD-73)
METRICS_ENABLED=true
